package about

import (
	"github.com/labstack/echo/v4"
	"github.com/FyrmForge/huginn/internal/web/components"
)

templ aboutPage(c echo.Context) {
	@components.Layout(c, "About") {
		<main class="max-w-4xl mx-auto px-6 py-16">
			<h1 class="text-4xl font-bold text-hamr-metal-steel mb-4">About</h1>
			<p class="text-lg text-hamr-metal-light max-w-xl">Tell the world about your project.</p>
		</main>
	}
}
